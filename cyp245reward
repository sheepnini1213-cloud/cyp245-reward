// ── 會長專區 ──
async function loadAdmin() {
    const cont = document.getElementById('admin-content');
    cont.innerHTML = '<p style="text-align:center;padding:20px;color:#999;">載入中...</p>';
    try {
        const res = await apiCall('getAdminDashboard');
