                    }
                    html += '</div>';
                });
                html += '</div>';
            });
        }

    } else if (tabName === 'stats') {
        const stats = adminDataCache.stats || { totalMembers: 0, totalReferrals: 0, totalEffective: 0 };
        html += '<div class="stats-grid"><div class="stat-card"><div class="stat-number">' + stats.totalMembers + '</div><div class="stat-label">總報名人數</div></div><div class="stat-card"><div class="stat-number">' + stats.totalReferrals + '</div><div class="stat-label">總推薦筆數</div></div><div class="stat-card"><div class="stat-number">' + stats.totalEffective + '</div><div class="stat-label">總達標人數</div></div></div>';

    } else if (tabName === 'yanqun') {
        const yanqunStats = adminDataCache.yanqunStats || [];
        if (yanqunStats.length === 0) {
            html += '<p style="text-align:center;padding:30px;color:#999;">目前無雁群資料</p>';
        } else {
            yanqunStats.forEach(function(g, gi) {
                const detailId = 'yanqun-detail-' + gi;
                html += '<div class="yanqun-frame"><div class="yanqun-top"><div class="yanqun-name">' + g.groupName + ' 小組</div><div class="yanqun-meta"><div class="yanqun-meta-item"><div class="yanqun-meta-num">' + g.totalPoints + '</div><div class="yanqun-meta-label">總分</div></div><div class="yanqun-meta-item"><div class="yanqun-meta-num">' + g.totalReferrals + '</div><div class="yanqun-meta-label">推薦人數</div></div><div class="yanqun-meta-item"><div class="yanqun-meta-num" style="color:#2E7D32;">' + g.effectiveCount + '</div><div class="yanqun-meta-label">有效推薦</div></div></div></div>';
                html += '<button class="yanqun-toggle" onclick="toggleDetail(\'' + detailId + '\',this)"><span>推薦明細</span><span>▼</span></button>';
                html += '<div class="yanqun-detail" id="' + detailId + '">';
                g.influencers.forEach(function(inv) {
                    html += '<div class="inv-group"><div class="inv-group-title">' + inv.name + ' <span style="font-weight:normal;font-size:12px;color:#888;">（總分 ' + inv.totalPoints + '）</span></div>';
                    inv.recruits.forEach(function(r) {
                        html += '<div class="inv-recruit-row ' + (r.points === 2 ? 'effective' : '') + '" style="flex-direction:column;align-items:flex-start;gap:4px;"><div style="display:flex;justify-content:space-between;width:100%;"><span>└ 推薦 <b>' + r.name + '</b></span><span class="tag ' + (r.points === 2 ? 'tag-green' : 'tag-plus1') + '">' + (r.points === 2 ? '有效推薦 +2' : '推薦 +1') + '</span></div><div style="font-size:11px;color:#999;padding-left:12px;">📅 ' + r.recDate + ' 登記' + (r.effDate ? ' | 🏆 ' + r.effDate + ' 達標' : '') + '</div></div>';
                    });
                    html += '</div>';
                });
                html += '</div></div>';
            });
        }

    } else if (tabName === 'roster') {
        const groupedRoster = adminDataCache.groupedRoster || {};
        const totalCount = adminDataCache.allUsers ? adminDataCache.allUsers.length : 0;
        html += '<div style="font-size:13px;color:#888;margin-bottom:14px;">共 ' + totalCount + ' 位參賽者</div>';
