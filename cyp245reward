    const warn = document.getElementById('proxy-amId-warn');
    if (!amId || !name || !group) { showToast('請填寫完整資料'); return; }
    if (warn.classList.contains('show')) { showToast('此編號已在名冊中，請確認'); return; }
    const btn = document.getElementById('btn-proxy-reg');
    btn.disabled = true; btn.innerText = '送出中...';
    try {
        const res = await apiCall('submitRegister', { uid: '', amId: amId, name: name, group: group });
        if (res.success) {
            // 加入已送出清單
            proxySubmittedList.push(name + '（' + amId + '）');
            const listDiv = document.getElementById('proxy-submitted-list');
            const namesDiv = document.getElementById('proxy-submitted-names');
            listDiv.style.display = 'block';
            namesDiv.innerHTML = proxySubmittedList.map(function(n, i) {
                return (i + 1) + '. ' + n;
            }).join('<br>');
            // 清空表單
            document.getElementById('proxy-amId').value = '';
            document.getElementById('proxy-name').value = '';
            document.getElementById('proxy-group').value = '';
            warn.classList.remove('show');
            showToast('✅ ' + name + ' 已送出！可繼續填寫下一位');
        } else {
            showToast(res.message);
        }
    } catch(e) { showToast('提交失敗'); }
    finally { btn.disabled = false; btn.innerText = '送出代報名'; }
}

// ── 初始化 ──
window.onload = function() {
    setupImageInput('tarImg', 'tarImg-preview', 'ref');
    setupImageInput('cImg', 'cImg-preview', 'cons');
    const isDev = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost';
    const goToHash = function() {
        const hash = window.location.hash.replace('#', '');
        if (hash === 'register') { openRegisterPage(); return; }
        if (hash && ['ref', 'cons', 'group', 'adm'].includes(hash)) switchTab(hash);
    };
    if (isDev) {
        state.uid = 'Uc374b29901f192ad5e8e0daf604bd238';
        refreshData().then(goToHash);
    } else {
        liff.init({ liffId: '2009757582-16dFzRuc' }).then(function() {
            if (!liff.isLoggedIn()) {
                liff.login();
            } else {
                liff.getProfile().then(function(p) {
                    state.uid = p.userId;
                    refreshData().then(goToHash);
                }).catch(function(err) {
                    console.error('getProfile error:', err);
                    document.getElementById('loading').style.display = 'none';
                    showToast('無法取得 LINE 身分，請重新開啟');
                });
            }
        }).catch(function(err) {
            console.error('liff.init error:', err);
            document.getElementById('loading').style.display = 'none';
            showToast('LIFF 初始化失敗：' + err.toString());
        });
    }
};
</script>
