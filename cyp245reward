async function approveRegister(amId, name, btnEl) {
    if (!confirm('確認「' + name + '」的報名？')) return;
    if (btnEl) { btnEl.disabled = true; btnEl.innerText = '處理中...'; }
    try {
        const res = await apiCall('approveRegister', { amId: amId, name: name });
        showToast(res.message);
        if (res.success) {
            // 直接移除這筆，不重整頁面
            const item = btnEl ? btnEl.closest('.reg-pending-item') : null;
            if (item) {
                item.style.transition = 'opacity 0.3s';
                item.style.opacity = '0';
                setTimeout(function() {
                    item.remove();
                    // 如果該雁群區塊已無成員，移除整個區塊
                    const frame = item.closest ? item.closest('.group-frame') : null;
                    if (frame && frame.querySelectorAll('.reg-pending-item').length === 0) frame.remove();
                }, 300);
            }
            // 更新 adminDataCache
            if (adminDataCache && adminDataCache.pendingRegistrations) {
                adminDataCache.pendingRegistrations = adminDataCache.pendingRegistrations.filter(function(r) { return r.amId !== amId; });
            }
        }
    } catch(e) {
        showToast('操作失敗');
        if (btnEl) { btnEl.disabled = false; btnEl.innerText = '✅ 確認報名'; }
    }
}
async function rejectRegister(amId, name, btnEl) {
    if (!confirm('確定退回「' + name + '」的報名？')) return;
    if (btnEl) { btnEl.disabled = true; btnEl.innerText = '處理中...'; }
    try {
        const res = await apiCall('rejectRegister', { amId: amId, name: name });
        showToast(res.message);
        if (res.success) {
            const item = btnEl ? btnEl.closest('.reg-pending-item') : null;
            if (item) {
                item.style.transition = 'opacity 0.3s';
                item.style.opacity = '0';
                setTimeout(function() {
                    item.remove();
                    const frame = item.closest ? item.closest('.group-frame') : null;
                    if (frame && frame.querySelectorAll('.reg-pending-item').length === 0) frame.remove();
                }, 300);
            }
            if (adminDataCache && adminDataCache.pendingRegistrations) {
                adminDataCache.pendingRegistrations = adminDataCache.pendingRegistrations.filter(function(r) { return r.amId !== amId; });
            }
        }
    } catch(e) {
        showToast('操作失敗');
        if (btnEl) { btnEl.disabled = false; btnEl.innerText = '❌ 退回'; }
    }
}

