function renderAwardContent(subTab) {
    if (!giftDataCache) return;
    const gifts = giftDataCache.gifts;
    const groupedReferrals = giftDataCache.groupedReferrals;
    const subTabs = ['referrals', 'unawarded', 'gifts'];
    const subLabels = ['推薦領獎', '未領獎', '禮物設定'];
    let html = '<div class="sub-tab-bar" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px;">';
    subTabs.forEach(function(t, i) {
        html += '<div class="sub-tab ' + (subTab === t ? 'active' : '') + '" onclick="renderAwardContent(\'' + t + '\')">' + subLabels[i] + '</div>';
    });
    html += '</div>';

    if (subTab === 'referrals') {
        if (!groupedReferrals || groupedReferrals.length === 0) {
            html += '<p style="text-align:center;color:#999;padding:20px;">尚無推薦紀錄</p>';
        } else {
            groupedReferrals.forEach(function(g) {
                html += '<div class="group-frame"><div class="group-header">' + g.groupName + ' 小組</div>';
                g.influencers.forEach(function(inv) {
                    html += '<div class="award-inv-block"><div class="award-inv-title">' + inv.invName + ' 推薦 ' + inv.recruits.length + ' 人</div>';
                    inv.recruits.forEach(function(rec) {
                        const ar = rec.awardRecord;
                        let statusHtml = '', rowClass = 'status-none';
                        if (ar) {
                            if (ar.status === '已領取') { rowClass = 'status-claimed'; statusHtml = '<span class="award-status-claimed">✅ ' + ar.claimDate + ' 領取 ' + ar.giftName + '</span>'; }
                            else { rowClass = 'status-pending'; statusHtml = '<span class="award-status-pending">⏳ 待領取（' + ar.registerDate + ' 登記）</span><button class="award-btn-green" onclick="openConfirmModal(' + ar.row + ',\'' + rec.tarName + '\')">確認已領取</button>'; }
                        } else {
                            statusHtml = '<span class="award-status-none">未登記</span><button class="award-btn-sm" onclick="openAwardModal(\'' + inv.invId + '\',\'' + rec.tarId + '\',\'' + rec.tarName + '\',\'' + inv.invName + '\')">登記禮物 ➔</button>';
                        }
                        html += '<div class="award-recruit-row ' + (rec.points === 2 ? 'effective ' : '') + rowClass + '"><div class="award-recruit-name">' + rec.tarName + ' <span class="tag ' + (rec.points === 2 ? 'tag-green' : 'tag-plus1') + '" style="margin-left:6px;">' + (rec.points === 2 ? '有效推薦' : '一般推薦') + '</span></div><div class="award-status-row">' + statusHtml + '</div></div>';
                    });
                    html += '</div>';
                });
                html += '</div>';
            });
        }
    } else if (subTab === 'unawarded') {
        let totalUnawarded = 0;
        if (groupedReferrals && groupedReferrals.length > 0) {
            groupedReferrals.forEach(function(g) {
                const unawardedInGroup = [];
                g.influencers.forEach(function(inv) {
                    inv.recruits.forEach(function(rec) {
                        if (!rec.awardRecord) unawardedInGroup.push(Object.assign({}, rec, { invId: inv.invId, invName: inv.invName }));
                    });
                });
                if (unawardedInGroup.length === 0) return;
                totalUnawarded += unawardedInGroup.length;
                html += '<div class="group-frame"><div class="group-header" style="border-left-color:#FF8F00;color:#FF8F00;">' + g.groupName + ' 小組（' + unawardedInGroup.length + ' 人未領）</div>';
                unawardedInGroup.forEach(function(rec) {
                    html += '<div class="card"><div><b>' + rec.tarName + '</b><span class="tag ' + (rec.points === 2 ? 'tag-green' : 'tag-plus1') + '" style="margin-left:6px;">' + (rec.points === 2 ? '有效推薦' : '一般推薦') + '</span><br><small style="color:#999;">推薦人：' + rec.invName + '</small></div><button class="award-btn-sm" onclick="openAwardModal(\'' + rec.invId + '\',\'' + rec.tarId + '\',\'' + rec.tarName + '\',\'' + rec.invName + '\')">登記 ➔</button></div>';
                });
                html += '</div>';
            });
        }
        if (totalUnawarded === 0) html += '<p style="text-align:center;color:#2E7D32;padding:20px;font-weight:bold;">🎉 所有人都已登記禮物！</p>';
    } else if (subTab === 'gifts') {
        const classroom = giftDataCache.myClassroom || '';
        html += '<div class="group-frame"><div class="group-header">新增禮物</div><div style="font-size:12px;color:var(--accent);font-weight:bold;margin-bottom:10px;">教室：' + classroom + '</div><label>禮物名稱</label><input type="text" id="new-gift-name" placeholder="例如：AirPods Pro"><label>數量（0 代表無限制）</label><input type="number" id="new-gift-total" placeholder="0"><label>備註（選填）</label><input type="text" id="new-gift-note"><button class="btn" onclick="addGift()">新增禮物</button></div>';
        html += '<div class="group-frame"><div class="group-header">目前禮物清單（' + classroom + '）</div>';
        if (!gifts || gifts.length === 0) {
            html += '<p style="text-align:center;color:#999;padding:10px;">尚無禮物</p>';
        } else {
            gifts.forEach(function(g) {
                const pct = g.total > 0 ? Math.round((g.used / g.total) * 100) : 0;
                html += '<div class="card" style="flex-direction:column;align-items:flex-start;"><div style="display:flex;justify-content:space-between;align-items:center;width:100%;margin-bottom:8px;"><span style="font-weight:bold;">🎁 ' + g.name + '</span><button type="button" onclick="deleteGift(\'' + g.name + '\')" style="background:none;border:none;color:#D32F2F;font-size:13px;font-weight:bold;cursor:pointer;">刪除</button></div>';
                if (g.total > 0) { html += '<div style="width:100%;background:#F0F0F0;border-radius:4px;height:6px;margin-bottom:6px;"><div style="width:' + pct + '%;background:' + (pct >= 100 ? '#D32F2F' : '#2E7D32') + ';height:6px;border-radius:4px;"></div></div><div style="font-size:12px;color:#999;">已發 ' + g.used + ' / 共 ' + g.total + '（剩 ' + g.remaining + '）</div>'; }
                else { html += '<div style="font-size:12px;color:#999;">已發 ' + g.used + '（無數量限制）</div>'; }
                if (g.note) html += '<div style="font-size:11px;color:#BBB;margin-top:2px;">' + g.note + '</div>';
                html += '</div>';
            });
        }
        html += '</div>';
    }
    document.getElementById('award-content').innerHTML = html;
}

function buildGiftOptions() {
    if (!giftDataCache || !giftDataCache.gifts) return '';
    return giftDataCache.gifts.map(function(g) {
        const disabled = g.remaining === 0 ? 'disabled' : '';
        const label = g.remaining === 0 ? g.name + '（已額滿）' : g.name + '（剩 ' + g.remaining + '）';
        return '<option value="' + g.name + '" ' + disabled + '>' + label + '</option>';
    }).join('');
}

