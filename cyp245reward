        renderAdminTab('regApprove');
    } catch(e) { cont.innerHTML = '<p style="text-align:center;padding:30px;color:red;">連線失敗</p>'; }
}

function renderAdminTab(tabName) {
    if (!adminDataCache) return;
    const cont = document.getElementById('admin-content');
    const tabs = ['regApprove', 'pending', 'reviewed', 'stats', 'yanqun', 'roster', 'award', 'contest'];
    const tabLabels = ['報名審核', '待審核', '審核紀錄', '績效統計', '雁群統計', '參賽名單', '頒獎管理', '競賽設定'];
    let html = '<div class="sub-tab-bar" style="grid-template-columns:repeat(4,1fr);">';
    tabs.forEach(function(t, i) {
        html += '<div class="sub-tab ' + (tabName === t ? 'active' : '') + '" onclick="renderAdminTab(\'' + t + '\')">' + tabLabels[i] + '</div>';
    });
    html += '</div>';

    if (tabName === 'regApprove') {
        const pendingRegs = adminDataCache.pendingRegistrations || [];
        if (pendingRegs.length === 0) {
            html += '<p style="text-align:center;padding:30px;color:#999;">目前無待確認報名 ✨</p>';
        } else {
            const regByGroup = {};
            pendingRegs.forEach(function(r) {
                if (!regByGroup[r.group]) regByGroup[r.group] = [];
                regByGroup[r.group].push(r);
            });
            Object.keys(regByGroup).forEach(function(gName) {
                html += '<div class="group-frame"><div class="group-header">' + gName + ' 雁群（' + regByGroup[gName].length + ' 人待確認）</div>';
                regByGroup[gName].forEach(function(r) {
                    html += '<div class="reg-pending-item"><div class="reg-pending-name">' + r.name + '</div><div class="reg-pending-meta">安麗編號：' + r.amId + '　｜　' + (r.lineId ? '已綁定 LINE' : '未綁定（代報名）') + '</div><div class="reg-action-row"><button class="btn" style="flex:1;margin:0;background:#2E7D32;padding:10px;" onclick="approveRegister(\'' + r.amId + '\',\'' + r.name + '\',this)">✅ 確認報名</button><button class="btn" style="flex:1;margin:0;background:#D32F2F;padding:10px;" onclick="rejectRegister(\'' + r.amId + '\',\'' + r.name + '\',this)">❌ 退回</button></div></div>';
                });
                html += '</div>';
            });
        }

    } else if (tabName === 'pending') {
        const pendingGroups = adminDataCache.pending || [];
        if (pendingGroups.length === 0) {
            html += '<p style="text-align:center;padding:30px;color:#999;">目前無待審核案件 ✨</p>';
        } else {
            pendingGroups.forEach(function(g) {
                html += '<div class="black-header">[ ' + g.groupName + ' ] 待審核</div><div class="card-body">';
                g.items.forEach(function(r) {
                    html += '<div style="margin-bottom:20px;border-bottom:1px dashed #EEE;padding-bottom:15px;"><div style="font-size:16px;font-weight:bold;margin-bottom:6px;">' + r.invName + ' ➔ ' + r.tarName + ' <span style="font-weight:normal;color:#666;">($' + r.amt + ')</span></div><div style="font-size:12px;color:#999;margin-bottom:10px;">類型: ' + (r.type || '未標記') + '</div>';
                    if (r.img) {
                        r.img.split(',').forEach(function(url, i) {
                            html += '<button type="button" class="btn" style="background:#F0F0F0;color:#000;margin-bottom:8px;padding:10px;height:auto;" onclick="viewImage(\'' + url.trim() + '\')">📸 查看憑證' + (r.img.split(',').length > 1 ? ' ' + (i + 1) : '') + '</button>';
                        });
                    }
                    html += '<div style="display:flex;gap:10px;"><button class="btn" style="flex:1;background:#000;margin:0;" onclick="processReview(' + r.row + ',\'approve\')">核准</button><button class="btn" style="flex:1;background:#666;margin:0;" onclick="processReview(' + r.row + ',\'reject\')">退回</button></div></div>';
                });
                html += '</div>';
            });
        }

    } else if (tabName === 'reviewed') {
        const reviewed = adminDataCache.reviewedItems || [];
        if (reviewed.length === 0) {
            html += '<p style="text-align:center;padding:30px;color:#999;">目前無已審核紀錄</p>';
        } else {
            const reviewedByGroup = {};
            reviewed.forEach(function(r) {
                const g = r.groupName || '未知小組';
                if (!reviewedByGroup[g]) reviewedByGroup[g] = [];
                reviewedByGroup[g].push(r);
            });
            Object.keys(reviewedByGroup).forEach(function(gName) {
                reviewedByGroup[gName].sort(function(a, b) {
                    if (a.status !== b.status) return a.status === '通過' ? -1 : 1;
                    return b.reviewedAt.localeCompare(a.reviewedAt);
                });
                const items = reviewedByGroup[gName];
                const approvedCount = items.filter(function(r) { return r.status === '通過'; }).length;
                const rejectedCount = items.length - approvedCount;
