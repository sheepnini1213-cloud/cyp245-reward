</div>

<script>
const GAS_URL = 'https://script.google.com/macros/s/AKfycbyxa8Zbw9EkZRfp-XWcdWRp_xMoBUeSVSIvHBKdW6WMSjd2C40faKjv_iiB58OBumtB/exec';
let state = { uid: '', reviewerName: '' };
let adminDataCache = null;
let giftDataCache = null;
let modalPayload = {};
let confirmPayload = {};
let selectedFiles = { ref: [], cons: [] };
let contestStatusCache = null;

// ── 工具函式 ──
function showToast(msg) {
    document.getElementById('toast-msg').innerText = msg;
    const t = document.getElementById('toast');
    t.style.display = 'block';
    setTimeout(() => { t.style.display = 'none'; }, 3000);
}

async function apiCall(action, payload) {
    const url = payload ? GAS_URL : GAS_URL + '?action=' + action + '&uid=' + state.uid;
    const opt = payload ? { method: 'POST', body: JSON.stringify({ action, payload }), redirect: 'follow' } : { method: 'GET' };
    const res = await fetch(url, opt);
    return res.json();
}

function setupImageInput(inputId, previewId, fileKey) {
    const input = document.getElementById(inputId);
    const previewArea = document.getElementById(previewId);
    input.addEventListener('change', () => {
        const newFiles = Array.from(input.files);
        const remaining = 5 - selectedFiles[fileKey].length;
        if (remaining <= 0) { showToast('最多只能上傳 5 張圖片'); input.value = ''; return; }
        const toAdd = newFiles.slice(0, remaining);
        if (newFiles.length > remaining) showToast('已達上限，只加入前 ' + remaining + ' 張');
        toAdd.forEach(file => { selectedFiles[fileKey].push(file); addPreviewItem(file, previewArea, fileKey); });
        input.value = '';
    });
}

function addPreviewItem(file, previewArea, fileKey) {
    const reader = new FileReader();
    reader.onload = function(e) {
        const dataUrl = e.target.result;
        const index = selectedFiles[fileKey].length - 1;
        const item = document.createElement('div');
        item.className = 'img-preview-item';
        item.dataset.index = index;
        const img = document.createElement('img');
        img.src = dataUrl;
        img.onclick = function() { viewImage(dataUrl); };
        const removeBtn = document.createElement('button');
        removeBtn.className = 'img-preview-remove';
        removeBtn.innerText = '✕';
        removeBtn.type = 'button';
        removeBtn.onclick = function(ev) {
            ev.stopPropagation();
            const idx = parseInt(item.dataset.index);
            selectedFiles[fileKey].splice(idx, 1);
            previewArea.querySelectorAll('.img-preview-item').forEach(function(el, i) { if (i > idx) el.dataset.index = i - 1; });
            item.remove();
        };
        item.appendChild(img);
        item.appendChild(removeBtn);
        previewArea.appendChild(item);
    };
    reader.readAsDataURL(file);
}

async function compressImage(file) {
    return new Promise(function(resolve) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const img = new Image();
            img.onload = function() {
                const canvas = document.createElement('canvas');
                const MAX = 1200;
                let w = img.width, h = img.height;
                if (w > h && w > MAX) { h = Math.round(h * MAX / w); w = MAX; }
                else if (h > MAX) { w = Math.round(w * MAX / h); h = MAX; }
                canvas.width = w; canvas.height = h;
                canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                resolve(canvas.toDataURL('image/jpeg', 0.75));
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    });
}

function viewImage(url) {
    document.getElementById('viewer-img').src = url;
    document.getElementById('image-viewer').style.display = 'flex';
}

function applyContestBanner(contestStatus) {
    contestStatusCache = contestStatus;
    ['contest-banner-ref', 'contest-banner-cons'].forEach(function(id) {
        const el = document.getElementById(id);
        if (!el) return;
        if (!contestStatus || contestStatus.status === 'active') { el.style.display = 'none'; return; }
        el.style.display = 'block';
        el.className = 'contest-banner ' + contestStatus.status;
        el.innerHTML = contestStatus.status === 'pending' ? '⏳ 目前競賽尚未開始，暫時無法提交' : '🔒 競賽已截止，無法繼續提交';
    });
    const isActive = !contestStatus || contestStatus.status === 'active';
    ['btn-ref', 'btn-cons'].forEach(function(id) {
        const btn = document.getElementById(id);
        if (btn) { btn.disabled = !isActive; btn.style.opacity = isActive ? '1' : '0.4'; }
    });
}

// ── 主資料載入 ──
async function refreshData() {
    try {
        const res = await apiCall('getInitData');
        if (res.data && res.data.error === '未註冊') {
            document.getElementById('reg-page').style.display = 'block';
            document.getElementById('ref').style.display = 'none';
            document.getElementById('main-tabs').style.display = 'none';
            return;
        }
        if (res.data) {
            const d = res.data;
            document.getElementById('reg-page').style.display = 'none';
            document.getElementById('main-tabs').style.display = 'flex';
            applyContestBanner(d.contestStatus);
            window._groupList = d.groupList || [];

            const classroom = d.myProfile.classroom || '';
            const group = d.myProfile.group || '';
            const classroomEl = document.getElementById('profile-classroom');
            const groupEl = document.getElementById('profile-group');
            const dividerEl = document.getElementById('profile-divider');
            if (classroom) { classroomEl.innerText = '所屬教室：' + classroom; classroomEl.style.display = 'inline'; } else { classroomEl.style.display = 'none'; }
            if (group) { groupEl.innerText = '所屬雁群：' + (group || '多重授權'); groupEl.style.display = 'inline'; } else { groupEl.style.display = 'none'; }
            dividerEl.style.display = (classroom && group) ? 'inline' : 'none';

            document.getElementById('inv-select').innerHTML = d.participants.map(function(m) {
                return '<option value="' + m.id + '">' + m.name + '</option>';
            }).join('');

            // 增加消費
            const groupedNewbies = d.newbies.reduce(function(acc, obj) {
                if (!acc[obj.group]) acc[obj.group] = [];
                acc[obj.group].push(obj);
                return acc;
            }, {});
            let consHtml = '';
            Object.keys(groupedNewbies).forEach(function(gName) {
                consHtml += '<div class="group-frame"><div class="group-header">' + gName + ' 雁群</div>';
                groupedNewbies[gName].forEach(function(m) {
                    const isReached = m.isReached;
                    consHtml += '<div class="card" onclick="' + (isReached ? '' : "selectForCons('" + m.tarId + "','" + m.name + "','" + m.invId + "','" + m.invName + "')") + '" style="' + (isReached ? 'opacity:0.5;background:#F0F0F0;' : '') + '">';
                    consHtml += '<div><b>' + (m.name || '未知') + '</b> <small>(' + m.tarId + ')</small>';
                    consHtml += '<br><small style="color:#888;">由 <b>' + m.invName + '</b> 推薦</small>';
                    consHtml += '<br><small>累計 $' + m.spent + '</small></div>';
                    consHtml += '<div style="color:var(--accent);font-weight:bold;">' + (isReached ? '✅ 已達標' : '補填 ➔') + '</div></div>';
                });
                consHtml += '</div>';
            });
            document.getElementById('member-list').innerHTML = consHtml || '<p style="text-align:center;color:#999;padding:20px;">目前無名單</p>';

            // 雁群小組：先顯示成員名單（從名冊），再顯示推薦戰報（從推薦總表）
            const groupMembers = d.groupMembers || [];
            const groupPerfMap = {};
            (d.groupPerf || []).forEach(function(g) { groupPerfMap[g.groupName] = g; });

            // 合併所有出現過的雁群（名冊有人 or 有推薦紀錄）
            const allGroupNames = [];
            groupMembers.forEach(function(g) { if (!allGroupNames.includes(g.groupName)) allGroupNames.push(g.groupName); });
            (d.groupPerf || []).forEach(function(g) { if (!allGroupNames.includes(g.groupName)) allGroupNames.push(g.groupName); });

            let groupHtml = allGroupNames.map(function(gName) {
                const memberData = groupMembers.find(function(g) { return g.groupName === gName; }) || { members: [] };
                const perfData = groupPerfMap[gName] || null;
                const members = memberData.members;

                // 成員收合區塊
                const confirmedCount = members.filter(function(m) { return m.status === '是'; }).length;
                const pendingCount = members.filter(function(m) { return m.status === '待確認'; }).length;
                const memberPanelId = 'member-panel-' + gName.replace(/[^a-zA-Z0-9]/g, '');
                const memberToggleLabel = '成員 ' + members.length + ' 人（✅ ' + confirmedCount + ' 已確認　⏳ ' + pendingCount + ' 審核中）';
                const memberTagsHtml = members.map(function(m) {
                    const cls = m.status === '是' ? 'confirmed' : 'pending';
                    const icon = m.status === '是' ? '✅' : '⏳';
                    return '<span class="member-tag ' + cls + '">' + icon + ' ' + m.name + '</span>';
                }).join('');
                const memberBlock = members.length > 0
                    ? '<button class="member-toggle" onclick="toggleMemberPanel(' + "'" + memberPanelId + "'" + ',this)"><span>' + memberToggleLabel + '</span><span>▼</span></button>' +
                      '<div class="member-panel" id="' + memberPanelId + '">' + memberTagsHtml + '</div>'
                    : '';

                // 推薦戰報區塊
                let influencersHtml = '';
                let scoreBar = '';
                if (perfData) {
                    scoreBar = '<div class="group-score-bar">' +
                        '<div class="group-score-item"><div class="group-score-num">' + perfData.groupTotalPoints + '</div><div class="group-score-label">總分</div></div>' +
                        '<div class="group-score-item"><div class="group-score-num" style="color:#333;">' + perfData.groupTotalReferrals + '</div><div class="group-score-label">推薦人數</div></div>' +
                        '<div class="group-score-item"><div class="group-score-num" style="color:#2E7D32;">' + perfData.groupEffectiveCount + '</div><div class="group-score-label">有效推薦</div></div>' +
                    '</div>';
                    influencersHtml = perfData.influencers.map(function(inv) {
                        const recruitsHtml = Object.values(inv.recruits).map(function(r) {
                            return '<div class="recruit-detail"><div style="display:flex;justify-content:space-between;"><span>推薦 <b>' + r.name + '</b></span><span class="tag ' + (r.points === 2 ? 'tag-green' : 'tag-plus1') + '">' + (r.points === 2 ? '有效推薦 +2' : '+1') + '</span></div><div style="font-size:11px;color:#999;margin-top:4px;">📅 登記: ' + r.recDate + (r.effDate ? ' | 🏆 達標: ' + r.effDate : ' (累計 $' + r.spent + ')') + '</div></div>';
                        }).join('');
                        return '<div class="perf-item"><div class="perf-title-row"><span style="font-weight:bold;font-size:16px;">' + inv.name + '</span><span style="font-size:13px;color:#666;">推薦:' + inv.count + ' | <b style="color:var(--accent)">總分:' + inv.totalPoints + '</b></span></div>' + recruitsHtml + '</div>';
                    }).join('');
                }

                return '<div class="group-frame">' +
                    '<div class="group-header">' + gName + ' 小組</div>' +
                    scoreBar +
                    memberBlock +
                    influencersHtml +
                '</div>';
            }).join('');

            document.getElementById('group-perf-list').innerHTML = groupHtml || '<p style="text-align:center;color:#999;padding:30px;">目前無資料</p>';

            if (d.isPresident) {
                document.getElementById('t-adm').style.display = 'block';
                state.reviewerName = d.myProfile.name || '會長';
            }
        }
    } catch(e) {
        console.error('Refresh Error:', e);
        showToast('數據載入異常，請重整');
    } finally {
        document.getElementById('loading').style.display = 'none';
    }
}

